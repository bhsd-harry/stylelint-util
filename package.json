{
	"name": "@bhsd/stylelint-util",
	"version": "1.0.1",
	"homepage": "https://github.com/bhsd-harry/stylelint-util#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/stylelint-util/issues"
	},
	"license": "MIT",
	"author": "Bhsd",
	"files": [
		"/dist/"
	],
	"exports": "./dist/index.js",
	"type": "module",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"scripts": {
		"prepublishOnly": "npm run build",
		"build": "tsc && esbuild src/index.ts --charset=utf8 --target=es2024 --format=esm --outfile=dist/index.js",
		"lint:ts": "tsc --noEmit && eslint --cache .",
		"lint": "npm run lint:ts"
	},
	"dependencies": {
		"stylelint-config-recommended": "^18.0.0"
	},
	"devDependencies": {
		"@bhsd/code-standard": "^1.3.2",
		"@stylistic/eslint-plugin": "^5.5.0",
		"@typescript-eslint/eslint-plugin": "^8.46.4",
		"@typescript-eslint/parser": "^8.46.4",
		"esbuild": "^0.25.12",
		"eslint": "^9.39.1",
		"eslint-plugin-es-x": "^9.1.2",
		"eslint-plugin-eslint-comments": "^3.2.0",
		"eslint-plugin-jsdoc": "^61.2.1",
		"eslint-plugin-jsonc": "^2.21.0",
		"eslint-plugin-n": "^17.23.1",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-regexp": "^2.10.0",
		"eslint-plugin-unicorn": "^62.0.0",
		"stylelint": "^17.0.0",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=20.19.5"
	}
}
