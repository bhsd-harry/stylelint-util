{
	"name": "@bhsd/stylelint-util",
	"version": "1.0.2",
	"homepage": "https://github.com/bhsd-harry/stylelint-util#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/stylelint-util/issues"
	},
	"license": "MIT",
	"author": "Bhsd",
	"files": [
		"/dist/"
	],
	"exports": "./dist/index.js",
	"type": "module",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"scripts": {
		"ls": "npm i --package-lock-only && npm ls --package-lock-only --all --omit=dev",
		"prepublishOnly": "npm run build",
		"build": "tsc && esbuild src/index.ts --charset=utf8 --target=es2024 --format=esm --outfile=dist/index.js",
		"lint:ts": "tsc --noEmit && eslint --cache .",
		"lint": "npm run lint:ts"
	},
	"dependencies": {
		"stylelint-config-recommended": "^18.0.0"
	},
	"devDependencies": {
		"@bhsd/code-standard": "^2.4.2",
		"@typescript-eslint/parser": "^8.59.2",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.0",
		"stylelint": "^17.11.1",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": "^20.19.0 || ^22.13.0 || >=24.11.0"
	}
}
